# ── Database ──────────────────────────────────────────────────────────────────
# Dev:  file:./dev.db (local SQLite)
# Prod: libsql://your-db.turso.io (Turso — free tier)
DATABASE_URL="file:./dev.db"
# DATABASE_AUTH_TOKEN= (only needed for Turso in production)

# ── AI Provider ──────────────────────────────────────────────────────────────
# Which provider to use: openrouter | anthropic | openai | deepseek | gemini
# Leave blank to auto-detect from whichever API key is set below.
AI_PROVIDER=openrouter

# ── API Keys ─────────────────────────────────────────────────────────────────
# Only fill the one you want to use.
OPENROUTER_API_KEY=your-openrouter-key
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# DEEPSEEK_API_KEY=your-deepseek-key
# XIAOMI_API_KEY=your-xiaomi-key
