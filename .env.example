# ── Database ──────────────────────────────────────────────────────────────────
# Dev:  file:./dev.db (SQLite — not for production)
# Prod: Set this in Vercel Environment Variables
#   Free options: Neon (neon.tech) or Supabase (supabase.com) PostgreSQL
DATABASE_URL="file:./dev.db"

# ── AI Provider ──────────────────────────────────────────────────────────────
# Which provider to use: openrouter | anthropic | openai | deepseek | gemini
# Leave blank to auto-detect from whichever API key is set below.
# For free deployment: use OpenRouter (free models) or Google Gemini (free tier)
AI_PROVIDER=openrouter

# ── API Keys ─────────────────────────────────────────────────────────────────
# Only fill the one you want to use. Set in Vercel Environment Variables for prod.
OPENROUTER_API_KEY=your-openrouter-key
# GEMINI_API_KEY=your-gemini-key
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# DEEPSEEK_API_KEY=your-deepseek-key
